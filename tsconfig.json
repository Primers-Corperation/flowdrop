{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "*": ["src/*"]
    },
    "lib": ["DOM", "DOM.Iterable", "ESNext"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "src/core/**/*.js",
    "src/components/**/*.js"
  ],
  "exclude": [
    "**/node_modules",
    "**/Pods"
  ]
}